# Neon / Vercel Postgres (from Vercel dashboard → Storage → Postgres)
DATABASE_URL=
POSTGRES_URL=

# Gemini API (server-side only — never expose to client)
GEMINI_API_KEY=

# Auth (generate with: openssl rand -base64 32)
AUTH_SECRET=

# App URL for password reset emails (production: https://shr3d-it.vercel.app)
NEXT_PUBLIC_APP_URL=

# Resend — https://resend.com (free tier for password reset emails)
RESEND_API_KEY=
EMAIL_FROM=SHR3D_IT <onboarding@resend.dev>
